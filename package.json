{
  "name": "chatgpt-clone",
  "version": "1.0.0",
  "type": "module",
  "description": "Complete ChatGPT-like AI chatbot with free Hugging Face AI (no paid APIs)",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "nodemon server/server.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "install-all": "npm install && cd client && npm install && cd .."
  },
  "keywords": [
    "chatgpt",
    "ai",
    "chatbot",
    "huggingface",
    "free",
    "open-source",
    "react",
    "express"
  ],
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/chatgpt-clone.git"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-fetch": "^3.3.2",
    "openai": "^6.34.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
